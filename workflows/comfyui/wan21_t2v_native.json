{
  "_meta": {
    "name": "WAN 2.1 Text-to-Video (Native Nodes)",
    "description": "Native WAN 2.1 workflow using ComfyUI-WAN extension nodes. Requires the ComfyUI-WAN custom node pack to be installed.",
    "version": "1.0",
    "author": "AI Studio",
    "status": "TODO — requires ComfyUI-WAN extension verification",
    "requires": [
      "ComfyUI-WAN custom nodes (https://github.com/kijai/ComfyUI-WanVideoWrapper)",
      "WAN 2.1 T2V 14B checkpoint",
      "WAN 2.1 CLIP model",
      "WAN 2.1 VAE"
    ],
    "notes": "Node class names may vary between ComfyUI-WAN extension versions. Verify against your installed version. This workflow uses the kijai/ComfyUI-WanVideoWrapper node names.",
    "placeholders": {
      "__POSITIVE_PROMPT__": "Video generation prompt",
      "__NEGATIVE_PROMPT__": "Negative prompt",
      "__WIDTH__": "Output width (default 832)",
      "__HEIGHT__": "Output height (default 480)",
      "__NUM_FRAMES__": "Number of frames (default 49, ~2s at 24fps)",
      "__STEPS__": "Sampling steps (default 20)",
      "__CFG__": "CFG scale (default 6.0)",
      "__SEED__": "Seed (-1 for random)",
      "__MODEL__": "WAN model name (wan2.1_t2v_14B_bf16.safetensors)"
    }
  },
  "1": {
    "class_type": "DownloadAndLoadWanModel",
    "inputs": {
      "model": "Wan-AI/Wan2.1-T2V-14B",
      "precision": "bf16",
      "quantization": "disabled"
    },
    "_meta": {"title": "Load WAN 2.1 Model"}
  },
  "2": {
    "class_type": "WanClipLoader",
    "inputs": {
      "model": "Wan-AI/Wan2.1-T2V-14B",
      "precision": "bf16"
    },
    "_meta": {"title": "Load WAN CLIP"}
  },
  "3": {
    "class_type": "WanVAELoader",
    "inputs": {
      "model": "Wan-AI/Wan2.1-T2V-14B",
      "precision": "bf16"
    },
    "_meta": {"title": "Load WAN VAE"}
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "__POSITIVE_PROMPT__",
      "clip": ["2", 0]
    },
    "_meta": {"title": "Positive Prompt"}
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "__NEGATIVE_PROMPT__",
      "clip": ["2", 0]
    },
    "_meta": {"title": "Negative Prompt"}
  },
  "6": {
    "class_type": "WanTextToVideo",
    "inputs": {
      "model": ["1", 0],
      "positive": ["4", 0],
      "negative": ["5", 0],
      "width": "__WIDTH__",
      "height": "__HEIGHT__",
      "num_frames": "__NUM_FRAMES__",
      "steps": "__STEPS__",
      "cfg": "__CFG__",
      "seed": "__SEED__",
      "scheduler": "flow_match_euler_shift",
      "shift": 5.0,
      "denoise_strength": 1.0
    },
    "_meta": {"title": "WAN Text-to-Video Sampler"}
  },
  "7": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["6", 0],
      "vae": ["3", 0]
    },
    "_meta": {"title": "WAN VAE Decode"}
  },
  "8": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["7", 0],
      "frame_rate": 24,
      "loop_count": 0,
      "filename_prefix": "aistudio_wan21",
      "format": "video/h264-mp4",
      "save_output": true
    },
    "_meta": {"title": "Save Video (MP4)"}
  }
}
