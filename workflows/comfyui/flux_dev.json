{
  "_meta": {
    "name": "Flux Dev Text-to-Image (Proper)",
    "description": "Correct Flux Dev workflow using UNETLoader + DualCLIPLoader + CLIPTextEncodeFlux. Requires separate CLIP-L, T5-XXL, and VAE files.",
    "version": "2.0",
    "author": "AI Studio",
    "requires": [
      "flux1-dev.safetensors (in models/diffusion_models/)",
      "clip_l.safetensors (in models/clip/)",
      "t5xxl_fp16.safetensors (in models/clip/)",
      "ae.safetensors (in models/vae/)"
    ],
    "placeholders": {
      "__CLIP_L_PROMPT__": "Short prompt for CLIP-L (77 tokens max)",
      "__T5_PROMPT__": "Detailed prompt for T5-XXL (up to 512 tokens)",
      "__WIDTH__": "Output width (default 1024)",
      "__HEIGHT__": "Output height (default 1024)",
      "__STEPS__": "Sampling steps (default 20)",
      "__GUIDANCE__": "Flux guidance scale (default 3.5)",
      "__SEED__": "Seed (-1 for random)"
    }
  },
  "1": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "flux1-dev.safetensors",
      "weight_dtype": "default"
    },
    "_meta": {"title": "Load Flux UNET"}
  },
  "2": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "clip_l.safetensors",
      "clip_name2": "t5xxl_fp16.safetensors",
      "type": "flux"
    },
    "_meta": {"title": "Load Dual CLIP (CLIP-L + T5-XXL)"}
  },
  "3": {
    "class_type": "CLIPTextEncodeFlux",
    "inputs": {
      "clip": ["2", 0],
      "clip_l": "__CLIP_L_PROMPT__",
      "t5xxl": "__T5_PROMPT__",
      "guidance": "__GUIDANCE__"
    },
    "_meta": {"title": "Flux Text Encode"}
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "__WIDTH__",
      "height": "__HEIGHT__",
      "batch_size": 1
    },
    "_meta": {"title": "Empty Latent"}
  },
  "5": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["3", 0],
      "negative": ["3", 0],
      "latent_image": ["4", 0],
      "seed": "__SEED__",
      "steps": "__STEPS__",
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0
    },
    "_meta": {"title": "KSampler"}
  },
  "6": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "ae.safetensors"
    },
    "_meta": {"title": "Load Flux VAE"}
  },
  "7": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["5", 0],
      "vae": ["6", 0]
    },
    "_meta": {"title": "VAE Decode"}
  },
  "8": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["7", 0],
      "filename_prefix": "aistudio_flux"
    },
    "_meta": {"title": "Save Image"}
  }
}
