# =============================================================================
# AI Studio .gitignore
# =============================================================================

# ── Environment & Secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.staging
*.pem
*.key
*.p12
secrets/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.venv/
venv/
env/
ENV/
.virtualenv/
.python-version
pip-log.txt
pip-delete-this-directory.txt

# ── uv ────────────────────────────────────────────────────────────────────────
.uv/
uv.lock

# ── Testing ──────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
nosetests.xml
test-results/
*.log

# ── Type checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# ── Ruff / Linting ───────────────────────────────────────────────────────────
.ruff_cache/

# ── Node / Frontend ──────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.yarn/
.pnp.*
*.tsbuildinfo
.next/
.nuxt/
.output/
dist/
out/

# ── Docker ───────────────────────────────────────────────────────────────────
# (keep Dockerfiles but ignore local build artefacts)
.docker/
docker-data/

# ── Supabase ─────────────────────────────────────────────────────────────────
supabase/.temp/
supabase/.branches/

# ── AI / ML artefacts ────────────────────────────────────────────────────────
*.ckpt
*.safetensors
*.pt
*.pth
*.bin
*.gguf
lora_output/
training_output/
model_cache/
/models/
!/frontend/src/app/models/
!models/.gitkeep

# ── ComfyUI ───────────────────────────────────────────────────────────────────
comfyui_output/
output/
input/
temp/
workflows/generated/

# ── Media output ─────────────────────────────────────────────────────────────
generated_images/
generated_videos/
generated_audio/
assets/generated/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# ── Windows ──────────────────────────────────────────────────────────────────
Thumbs.db
Thumbs.db:encdata
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# ── Linux ────────────────────────────────────────────────────────────────────
*~
.nfs*

# ── IDEs ─────────────────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/settings.json
.vscode/launch.json
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ── Celery ───────────────────────────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid

# ── Uploads / Temp ───────────────────────────────────────────────────────────
uploads/
tmp/
temp/
*.tmp

# ── Compiled docs ────────────────────────────────────────────────────────────
docs/_build/
site/

# ── Alembic ──────────────────────────────────────────────────────────────────
# Keep migrations, ignore local state
backend/alembic/versions/__pycache__/
frontend/node_modules
frontend/.next
frontend/.env.local
