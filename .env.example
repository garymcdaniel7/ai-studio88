# =============================================================================
# AI Studio - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development                     # development | staging | production
APP_NAME=ai-studio
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR | CRITICAL
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
API_PREFIX=/api/v1
WORKERS=1                               # Increase in production

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── Database (direct connection) ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Backblaze B2 Storage ──────────────────────────────────────────────────────
B2_KEY_ID=your-b2-key-id
B2_APPLICATION_KEY=your-b2-application-key
B2_BUCKET_NAME=ai-studio-assets
B2_BUCKET_ID=your-bucket-id
B2_ENDPOINT_URL=https://s3.us-west-000.backblazeb2.com
B2_REGION=us-west-000
B2_CDN_URL=https://cdn.yourdomain.com    # Optional CDN in front of B2

# ── Vast.ai GPU Provider ──────────────────────────────────────────────────────
VASTAI_API_KEY=your-vastai-api-key
VASTAI_DEFAULT_DISK_GB=50
VASTAI_DEFAULT_GPU_TYPE=RTX_4090
VASTAI_DEFAULT_NUM_GPUS=1
VASTAI_SSH_KEY_PATH=~/.ssh/id_rsa

# ── RunPod GPU Provider (future) ──────────────────────────────────────────────
RUNPOD_API_KEY=your-runpod-api-key
RUNPOD_DEFAULT_GPU_TYPE=NVIDIA RTX 4090

# ── ComfyUI ───────────────────────────────────────────────────────────────────
COMFYUI_BASE_URL=http://localhost:8188
COMFYUI_WORKFLOWS_DIR=./workflows
COMFYUI_OUTPUT_DIR=./output
COMFYUI_TIMEOUT_SECONDS=300

# ── Redis (job queue / caching) ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Authentication ────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Multi-tenant SaaS ─────────────────────────────────────────────────────────
# Each tenant maps to a Supabase project or schema.
ENABLE_MULTITENANCY=true
DEFAULT_TENANT_PLAN=starter            # starter | pro | enterprise

# ── AI Generation Defaults ───────────────────────────────────────────────────
DEFAULT_IMAGE_WIDTH=1024
DEFAULT_IMAGE_HEIGHT=1024
DEFAULT_IMAGE_STEPS=20
DEFAULT_VIDEO_FPS=24
DEFAULT_VIDEO_DURATION_SECONDS=5

# ── LoRA Training ─────────────────────────────────────────────────────────────
LORA_TRAINING_BASE_MODEL=black-forest-labs/FLUX.1-dev
LORA_TRAINING_OUTPUT_DIR=./lora_output
LORA_TRAINING_MAX_STEPS=1000

# ── Monitoring / Observability ────────────────────────────────────────────────
SENTRY_DSN=                            # Leave empty to disable
OTEL_EXPORTER_OTLP_ENDPOINT=          # OpenTelemetry collector endpoint
ENABLE_METRICS=false

# ── Email (transactional) ────────────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=your-smtp-password
FROM_EMAIL=noreply@yourdomain.com

# ── Stripe (billing) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_STARTER_PRICE_ID=price_your-starter-price-id
STRIPE_PRO_PRICE_ID=price_your-pro-price-id

# ── Feature Flags ────────────────────────────────────────────────────────────
FEATURE_VIDEO_GENERATION=true
FEATURE_VOICE_GENERATION=false
FEATURE_LORA_TRAINING=true
FEATURE_ANALYTICS=true

# ── Generation Engine ─────────────────────────────────────────────────────────
GENERATION_PROVIDER=simulation          # simulation | comfyui
